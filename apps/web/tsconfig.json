{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@nyx-os/ai": ["../../packages/ai/src/index.ts"],
      "@nyx-os/automation": ["../../packages/automation/src/index.ts"],
      "@nyx-os/capabilities": ["../../packages/capabilities/src/index.ts"],
      "@nyx-os/config": ["../../packages/config/src/index.ts"],
      "@nyx-os/context": ["../../packages/context/src/index.ts"],
      "@nyx-os/core": ["../../packages/core/src/index.ts"],
      "@nyx-os/database": ["../../packages/database/src/index.ts"],
      "@nyx-os/event-bus": ["../../packages/event-bus/src/index.ts"],
      "@nyx-os/knowledge": ["../../packages/knowledge/src/index.ts"],
      "@nyx-os/logger": ["../../packages/logger/src/index.ts"],
      "@nyx-os/local-gateway": ["../../packages/local-gateway/src/index.ts"],
      "@nyx-os/memory": ["../../packages/memory/src/index.ts"],
      "@nyx-os/plugin": ["../../packages/plugin/src/index.ts"],
      "@nyx-os/personal-data": ["../../packages/personal-data/src/index.ts"],
      "@nyx-os/prompt": ["../../packages/prompt/src/index.ts"],
      "@nyx-os/scheduler": ["../../packages/scheduler/src/index.ts"],
      "@nyx-os/state": ["../../packages/state/src/index.ts"],
      "@nyx-os/tools": ["../../packages/tools/src/index.ts"],
      "@nyx-os/workflow": ["../../packages/workflow/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
