{
  "name": "nyx-os",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @nyx-os/web run dev",
    "build": "npm --workspace @nyx-os/web run build",
    "start": "npm --workspace @nyx-os/web run start",
    "lint": "npm --workspace @nyx-os/web run lint",
    "test": "npm --workspace @nyx-os/web run test --",
    "test:watch": "npm --workspace @nyx-os/web run test:watch --"
  },
  "overrides": {
    "postcss": "^8.5.16",
    "serialize-javascript": "^7.0.7"
  }
}
